{% extends "__layout.twig" %}

{% block content %}
<form action="">
    <select name="type">
        <option value="север" {% if type == 'север' %}selected{% endif %}>Север</option>
        <option value="юг" {% if type == 'юг' %}selected{% endif %}>Юг</option>
    </select>
    <label>Название <input type="text" name="title"></label>
    <label>Описание <input type="text" name="info"></label>

    <button type="submit">Найти</button>
</form>

{% for obj in objects %}
    <a href="">{{ obj.title }}</a><br>
{% else %}
    <p>Ничего не найдено</p>
{% endfor %}
{% endblock %}