{% extends "__layout.twig" %}

{% block content %}
{% from 'macros.twig' import btn %}

<h1>{{title}}</h1>
{{description}}

<ul class="nav nav-pills" style="margin:10px;">
  <li class="nav-item">
    {{ btn("Картинка", "/" ~ url_title ~ "/image", is_image, "warning") }}
  </li>
  <li class="nav-item">
    {{ btn("Описание", "/" ~ url_title ~ "/info", is_info, "warning") }}
  </li>
</ul>

{% block objectContent %}{% endblock %}

{% endblock %}