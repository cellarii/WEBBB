
{% extends "__layout.twig" %}

{% block content %}
<div class="row d-flex">
    {% for object in vasteras_area %}
    <div class="col mb-4 d-flex align-items-stretch">
        <div class="border p-2 d-flex flex-column justify-content-between w-100 position-relative">
            <div class="position-absolute" style="left:4px; top:4px;">
            <a href="/vasteras-area/{{ object.id }}/edit">
            <button type="submit" class="btn btn-info">
                    <i class ="fas fa-edit"></i>
            </button>
            </a>
        </div>
            <div class="position-absolute" style="right: 4px; top: 4px">
                <form action="/vasteras-area/{{object.id}}/delete" method="POST">
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-times"></i>
                    </button>
                </form>
            </div>
            <div class="img-thumbnail mb-2" style="width: 100%; height: 200px; overflow:hidden">
                <img src="{{ object.image }}" style="height: 100%; width: 100%; object-fit: cover;" alt="">
            </div>
            <div class="d-flex flex-column">
                <a href="/vasteras-area/{{object.id}}" type="button" class="btn btn-primary mb-1">{{ object.title }}</a>
                <div class="d-flex justify-content-center">
                    <a class="me-3" href="/vasteras-area/{{object.id}}?show=image">Картинка</a>
                    <a href="/vasteras-area/{{object.id}}?show=info">Описание</a>
                </div>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% endblock %}