<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.2/css/all.min.css" rel="stylesheet">
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-light bg-light">
    <div class="container">
        <a class="navbar-brand" href="#"><i class="fas fa-meteor"></i></a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" href="/">Главная</a>
                </li>
                {% for type in types %}
                <li class="nav-item">
                    <a class="nav-link" href="/?type={{type.name}}">{{type.name|title}}</a>
                </li>
                {% endfor %}
                <li class="nav-item">
                    <a class="nav-link" href="/search">Поиск</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/vasteras-area/create">Добавить объект</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/new-type/create">Добавить тип</a>
                </li>
            </ul>
        </div>
        <form action="/set-welcome/">
            <input type="text" name="message" class="form-control" placeholder="Введите сообщение">
        </form>
    </div>
</nav>

<div style="display: flex;">
    <div class="container" style="padding-top: 20px; flex: 1;">
        {% block content %}{% endblock %}
    </div>

    <!-- Блок с историей посещений -->
    <div style="padding-right: 2%; padding-top: 1%; min-width: 250px; max-width: 300px;">
        <strong>Последние страницы, которые вы посетили:</strong><br>
        {% if visited_urls|length > 0 %}
            {% for url in visited_urls %}
                <div class="p-2 rounded text-break" style="background-color: #e3f2fd; margin-top: 5px; border-radius: 5px;">
                    <a href="{{ url }}" style="color: black; text-decoration: none;">{{ url }}</a>
                </div>
            {% endfor %}
        {% else %}
            <div class="text-muted">Нет истории</div>
        {% endif %}
    </div>
</div>

</body>
</html>